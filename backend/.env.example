# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# CORS: vesszővel elválasztott lista a megengedett origin-ekről.
# Üresen hagyva minden origin (lokális fejlesztéshez).
# Prod példa: https://gofuvar.hu,https://www.gofuvar.hu
CORS_ORIGIN=

# --- PostgreSQL / Supabase / Neon / Railway ---
DATABASE_URL=postgres://user:password@localhost:5432/gofuvar
# Prod hostolt Postgres (Neon, Supabase, Railway, Render) SSL-t igényel.
# Állítsd `require`-re, vagy tedd a DATABASE_URL végére: ?sslmode=require
PGSSL=

# --- Google Gemini ---
# API kulcs a https://aistudio.google.com/app/apikey oldalról.
# Aktuális modell: gemini-2.5-flash (default). Nagyobb: gemini-2.5-pro.
# A gemini-1.5-* és gemini-2.0-* sorozatokat a Google kivezette.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Email (Resend) ---
# Tranzakciós email küldéshez. Hagyd üresen STUB módhoz: fejlesztés
# közben a maileket csak a konzolra logolja (nem megy el a Resendre).
# Kulcs a https://resend.com/api-keys oldalról, saját EMAIL_FROM-hoz
# előbb verify-olj egy domain-t a dashboardon.
RESEND_API_KEY=
EMAIL_FROM=GoFuvar <onboarding@resend.dev>

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- Delivery validation ---
DELIVERY_MAX_DISTANCE_METERS=50

# --- Barion Bridge (fizetés) ---
# Hagyd üresen STUB módhoz (fejlesztéskor sandbox nélkül is működik).
BARION_POS_KEY=
BARION_ENV=test                          # test | prod
BARION_PLATFORM_PAYEE=platform@gofuvar.hu
BARION_RESERVATION_PERIOD=1.00:00:00     # 1 nap (Barion ISO 8601 timespan)
PLATFORM_COMMISSION_PCT=0.10             # 10% jutalék
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
