# Backend URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Maps JavaScript API kulcs (Shipper Dashboard térkép + élő követés)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Sentry (error monitoring). DSN-t a sentry.io dashboard-ról.
# A NEXT_PUBLIC_ verziót a böngésző is látja (kliens-oldali hibákhoz);
# a SENTRY_DSN a server-side render hibákhoz kell.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
